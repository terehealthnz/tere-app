# Tere Health — environment variable template
# All values use 1Password op:// references.
# This file is SAFE to commit to git — no secrets here.
#
# Usage:
#   op run --env-file=".env.example" -- npm run dev
#
# Or use the npm alias:
#   npm run dev:op
#
# First-time setup:
#   brew install 1password-cli
#   op signin
#   Then run: npm run dev:op

# ── Supabase ──────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL="op://Tere Production/Supabase/url"
VITE_SUPABASE_ANON_KEY="op://Tere Production/Supabase/anon_key"
SUPABASE_SERVICE_ROLE_KEY="op://Tere Production/Supabase/service_role_key"

# ── Stripe ────────────────────────────────────────────────────────────────────
VITE_STRIPE_PUBLISHABLE_KEY="op://Tere Production/Stripe/publishable_key"
STRIPE_SECRET_KEY="op://Tere Production/Stripe/secret_key"

# ── Twilio (SMS / voice) ──────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID="op://Tere Production/Twilio/account_sid"
TWILIO_AUTH_TOKEN="op://Tere Production/Twilio/auth_token"
TWILIO_PHONE_NUMBER="op://Tere Production/Twilio/phone_number"
VITE_TWILIO_PHONE_NUMBER="op://Tere Production/Twilio/phone_number"

# ── Resend (email) ────────────────────────────────────────────────────────────
RESEND_API_KEY="op://Tere Production/Resend/api_key"
RESEND_FROM_EMAIL=hello@terehealth.co.nz

# ── LiveKit (video) ───────────────────────────────────────────────────────────
LIVEKIT_API_KEY="op://Tere Production/LiveKit/api_key"
LIVEKIT_API_SECRET="op://Tere Production/LiveKit/api_secret"
LIVEKIT_URL="op://Tere Production/LiveKit/url"

# ── Deepgram (transcription) ──────────────────────────────────────────────────
DEEPGRAM_API_KEY="op://Tere Production/Deepgram/api_key"
VITE_DEEPGRAM_API_KEY="op://Tere Production/Deepgram/api_key"

# ── Anthropic (AI) ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY="op://Tere Production/Anthropic/api_key"

# ── VAPID (push notifications) ────────────────────────────────────────────────
VAPID_PUBLIC_KEY="op://Tere Production/VAPID/public_key"
VAPID_PRIVATE_KEY="op://Tere Production/VAPID/private_key"
VITE_VAPID_PUBLIC_KEY="op://Tere Production/VAPID/public_key"

# ── Tere internal ─────────────────────────────────────────────────────────────
TERE_API_KEY="op://Tere Production/Tere Internal/api_key"
VITE_TERE_API_KEY="op://Tere Production/Tere Internal/api_key"
VITE_CLINICIAN_PIN="op://Tere Production/Tere Internal/clinician_pin"
VITE_VALIDATION_PIN="op://Tere Production/Tere Internal/validation_pin"

# ── Daily.co (legacy, keep until fully migrated off) ─────────────────────────
DAILY_API_KEY="op://Tere Production/Daily.co/api_key"

# ── ACC API ───────────────────────────────────────────────────────────────────
# Register as vendor: call ACC 0800 222 994 or email ProviderHelpdesk@acc.co.nz
# Sandbox: https://apiservicesnpe.acc.co.nz
# Production: https://apiservices.acc.co.nz
ACC_API_KEY="op://Tere Clinical/ACC API/api_key"
ACC_VENDOR_ID="op://Tere Clinical/ACC API/vendor_id"
ACC_API_URL=https://apiservicesnpe.acc.co.nz
ACC_WEBHOOK_SECRET="op://Tere Clinical/ACC API/webhook_secret"

# ── NZePS (electronic prescriptions) ─────────────────────────────────────────
# Register at https://nzeps.health.govt.nz/providers
NZEPS_API_KEY="op://Tere Clinical/NZePS/api_key"
NZEPS_API_URL=https://nzeps-sandbox.health.govt.nz

# ── HealthLink (referrals / FHIR) ────────────────────────────────────────────
# Register at https://www.healthlink.net/contact
HEALTHLINK_API_KEY="op://Tere Clinical/HealthLink/api_key"
HEALTHLINK_API_URL=https://api.healthlink.net/sandbox

# ── Banking (payroll / provider payments) ────────────────────────────────────
BANK_ACCOUNT_NUMBER="op://Tere Admin/Banking/account_number"
BANK_API_KEY="op://Tere Admin/Banking/api_key"

# ── Firebase (native push notifications via Capacitor) ───────────────────────
# 1. Create project at https://console.firebase.google.com
# 2. Project Settings → Service accounts → Generate new private key
# 3. Paste the entire JSON object (minified) as the value below
# 4. Add APNs key: Project Settings → Cloud Messaging → iOS app → Upload APNs key
# 5. Place google-services.json in android/app/ and GoogleService-Info.plist in ios/App/App/
FIREBASE_SERVICE_ACCOUNT="op://Tere Production/Firebase/service_account_json"
VITE_FIREBASE_APP_ID="op://Tere Production/Firebase/app_id"

# ── Feature flags (not secrets — fine as plain values) ───────────────────────
VITE_BOOKING_ENABLED=false
VITE_QUEUE_ENABLED=false
